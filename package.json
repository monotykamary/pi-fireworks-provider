{
  "name": "pi-fireworks-provider",
  "version": "1.4.1",
  "description": "Fireworks AI provider extension for pi - Access Kimi, MiniMax, GLM, DeepSeek, and GPT-OSS models through the Fireworks AI API",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "clean": "echo 'nothing to clean'",
    "build": "echo 'nothing to build'",
    "check": "tsc --noEmit && vitest run && knip --no-gitignore",
    "lint:dead": "knip --no-gitignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "update-models": "node scripts/update-models.js"
  },
  "keywords": [
    "pi",
    "extension",
    "provider",
    "fireworks",
    "fireworks-ai",
    "ai",
    "llm",
    "kimi",
    "minimax",
    "glm",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "files": [
    "index.ts",
    "models.json",
    "custom-models.json",
    "patch.json",
    "README.md",
    "LICENSE"
  ],
  "devDependencies": {
    "@types/node": "^22.20.0",
    "knip": "6.14.1",
    "typescript": "6.0.3",
    "vitest": "4.1.7"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "packageManager": "pnpm@11.6.0"
}
